# ── Gemini (Phase 2 & 3) ──────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google OAuth 2.0 (Phase 5 — MCP: Docs + Gmail) ───────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth/callback

# For Headless Environments (Render): Paste the entire Service Account JSON here
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Google Docs (Phase 5) ─────────────────────────────────────────────────────
# The Doc ID is in the URL: docs.google.com/document/d/<DOC_ID>/edit
GOOGLE_DOC_ID=your_google_doc_id_here

# ── Gmail (Phase 5 — SMTP) ───────────────────────────────────────────────────────────
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here
GMAIL_DRAFT_RECIPIENT=recipient@example.com
GMAIL_DRAFT_SUBJECT=Weekly Product Pulse — Groww App

# ── Security (Phase 5 — Custom Export) ──────────────────────────────────────────────
CUSTOM_EXPORT_PASSWORD=your_custom_export_password_here

# ── Scraper (Phase 1) ─────────────────────────────────────────────────────────
# Google Play app ID for Groww
GROWW_APP_ID=com.nextbillion.groww
DEFAULT_DAYS=7
